# Keycloak OIDC issuer (realm URL). With a port-forwarded Keycloak:
#   kubectl -n keycloak port-forward svc/keycloak 8081:8080
AUTH_KEYCLOAK_ISSUER=http://localhost:8081/realms/kubespaces

# Public client id — the Keycloak client "kubespaces" must be a PUBLIC client
# (no client secret) with PKCE (S256) and a redirect URI of
# ${AUTH_URL}/api/auth/callback/keycloak
AUTH_KEYCLOAK_ID=kubespaces

# Cookie/JWT encryption secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical URL of this app (used for OAuth callbacks + secure-cookie detection)
AUTH_URL=http://localhost:3000

# KubeSpaces backend API base URL. With a port-forwarded API:
#   kubectl -n kubespaces port-forward svc/kubespaces-api 8080:8080
KUBESPACES_API_URL=http://localhost:8080
